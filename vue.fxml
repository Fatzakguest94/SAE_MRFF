<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="856.0"
            prefWidth="1377.0"
            styleClass="root"
            xmlns="http://javafx.com/javafx/8.0.40"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="universite_paris8.iut.fabdelrahim.sae.controller.Controller">

    <!-- STYLE -->

    <stylesheets>
        <URL value="@Style.css"/>
    </stylesheets>

    <!-- ================= SIDEBAR ================= -->

    <right>

        <VBox alignment="TOP_CENTER"
              prefWidth="225.0"
              prefHeight="620.0"
              spacing="15"
              styleClass="sidebar">

            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <Label text="Tours"
                   styleClass="title"/>

            <!-- TOURS -->

            <HBox alignment="CENTER" spacing="15">

                <VBox alignment="CENTER" spacing="5">
                    <Button prefWidth="70" prefHeight="70"
                            text="100🎟"
                            styleClass="tower-button"   onAction="#gestionargent"/>
                    <Label text="Burger"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5">
                    <Button prefWidth="70" prefHeight="70"
                            text="150🎟"
                            styleClass="tower-button"/>
                    <Label text="Pizza"/>
                </VBox>

            </HBox>

            <HBox alignment="CENTER" spacing="15">

                <VBox alignment="CENTER" spacing="5">
                    <Button prefWidth="70" prefHeight="70"
                            text="200🎟"
                            styleClass="tower-button"/>
                    <Label text="Frites"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5">
                    <Button prefWidth="70" prefHeight="70"
                            text="300🎟"
                            styleClass="tower-button"/>
                    <Label text="Soda"/>
                </VBox>

            </HBox>

            <!-- ESPACE -->

            <Region prefHeight="10"/>

            <!-- LANCER -->

            <Button text="Lancer"
                    onAction="#lancerJeu"
                    styleClass="btn-play-big"
                    prefWidth="180"
                    prefHeight="120"/>

            <!-- ARRETER -->

            <Button text="Arrêter"
                    onAction="#arreterJeu"
                    styleClass="btn-stop"
                    prefWidth="180"
                    prefHeight="40"/>

            <!-- RECOMMENCER -->

            <Button text="Recommencer"
                    onAction="#recommencerJeu"
                    styleClass="btn-restart"
                    prefWidth="180"
                    prefHeight="40"/>

            <!-- ESPACE BAS -->

            <Region VBox.vgrow="ALWAYS"/>

        </VBox>

    </right>

    <!-- ================= CENTRE MAP ================= -->

    <center>

        <Pane>

            <TilePane fx:id="map"
                      styleClass="map"/>

            <Pane fx:id="panneauJeu"
                  style="-fx-background-color: transparent;">

                <ImageView fx:id="zombie"
                           fitWidth="35"
                           fitHeight="35"/>

                <ImageView fx:id="zombie1"
                           fitWidth="50"
                           fitHeight="50"/>

                <ImageView fx:id="zombie2"
                           fitWidth="35"
                           fitHeight="35"/>

                <ImageView fx:id="zombie3"
                           fitWidth="45"
                           fitHeight="45"/>

            </Pane>

        </Pane>

    </center>

    <!-- ================= BOTTOM ================= -->

    <bottom>

        <HBox alignment="CENTER_LEFT"
              prefHeight="100"
              spacing="40"
              styleClass="bottom-bar">

            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="Pizza : 100"
                   styleClass="info-label"/>

            <Label fx:id="labelArgent" styleClass="info-label"/>

            <Label text="Vague : 1"
                   styleClass="info-label"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="⚙ Réglages"   onAction="#reglage"
                    styleClass="btn"/>

        </HBox>

    </bottom>

</BorderPane>
