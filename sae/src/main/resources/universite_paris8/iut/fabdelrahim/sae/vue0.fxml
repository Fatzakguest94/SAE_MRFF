<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="856.0" prefWidth="1377.0" styleClass="root" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="universite_paris8.iut.fabdelrahim.sae.controller.Controller">

    <stylesheets>
        <URL value="@Style.css" />
    </stylesheets>

    <right>
        <VBox alignment="TOP_CENTER" prefHeight="620.0" prefWidth="225.0" spacing="15" styleClass="sidebar">

            <padding>
                <Insets bottom="20" left="15" right="15" top="20" />
            </padding>

            <Button fx:id="renomer" onMouseClicked="#rename" styleClass="title" text="Tours" />

            <HBox alignment="CENTER" spacing="15">

                <VBox alignment="CENTER" spacing="5">
                    <Button contentDisplay="top" onAction="#clicBoutonMitrailletteFrite" prefHeight="70" prefWidth="70" styleClass="tower-button" text="100">
                        <graphic>
                            <ImageView fitHeight="55" fitWidth="55">
                                <image>
                                    <Image url="@vue/frite.png"/>
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Label text="Mitra-Frites"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5">
                    <Button contentDisplay="top" onAction="#clicBoutonLanceBurger" prefHeight="70" prefWidth="70" styleClass="tower-button" text="150">
                        <graphic>
                            <ImageView fitHeight="55" fitWidth="55">
                                <image>
                                    <Image url="@vue/burger.png"/>
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Label text="Lance-Burger"/>
                </VBox>

            </HBox>

            <HBox alignment="CENTER" spacing="15">

                <VBox alignment="CENTER" spacing="5">
                    <Button contentDisplay="top" onAction="#clicBoutonBarbecue" prefHeight="70" prefWidth="70" styleClass="tower-button" text="200">
                        <graphic>
                            <ImageView fitHeight="55" fitWidth="55">
                                <image>
                                    <Image url="@vue/barbecue.png"/>
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Label text="Barbecue">
                  <font>
                     <Font name="GLYPHICONS Halflings Regular" size="13.0" />
                  </font></Label>
                </VBox>

                <VBox alignment="CENTER" spacing="5">
                    <Button contentDisplay="top" onAction="#clicBoutonBacGlace" prefHeight="70" prefWidth="70" styleClass="tower-button" text="300">
                        <graphic>
                            <ImageView fitHeight="55" fitWidth="55">
                                <image>
                                    <Image url="@vue/glace.png"/>
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Label text="Bac à Glace"/>
                </VBox>

            </HBox>

            <Region prefHeight="10" />

            <Button onAction="#lancerJeu" prefHeight="120" prefWidth="180" styleClass="btn-play-big" text="Lancer" />

            <Button onAction="#arreterJeu" prefHeight="40" prefWidth="180" styleClass="btn-stop" text="Arrêter" />

            <Button onAction="#recommencerJeu" prefHeight="40" prefWidth="180" styleClass="btn-restart" text="Recommencer" />

            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </right>

    <center>

        <Pane>

            <TilePane fx:id="map" styleClass="map" />

            <Pane fx:id="panneauJeu" onMouseClicked="#clicSurTerrain" style="-fx-background-color: transparent;" />
        </Pane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="100" spacing="40" styleClass="bottom-bar">

            <padding>
                <Insets bottom="10" left="20" right="20" top="10" />
            </padding>

            <Label fx:id="labelHpBase" styleClass="info-label" />

            <Label fx:id="labelArgent" styleClass="info-label" />

            <Label fx:id="labelVague" styleClass="info-label" />

            <Region HBox.hgrow="ALWAYS" />

            <Button onAction="#bestiaire" styleClass="btn" text="Bestiaire" />
            <Button onAction="#aide" styleClass="btn" text="Aide?" />
            <Button layoutX="1097.0" layoutY="41.0" onAction="#reglage" styleClass="btn" text="Réglages" />


        </HBox>
    </bottom>

</BorderPane>
