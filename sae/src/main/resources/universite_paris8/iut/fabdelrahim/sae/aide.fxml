<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="universite_paris8.iut.fabdelrahim.sae.controller.Controller"
           prefWidth="1377"
           prefHeight="856"
           style="-fx-background-color: linear-gradient(to bottom right, #200508, #0f0203, #2a0a0e);">

    <VBox alignment="CENTER" spacing="30" maxWidth="1300">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>

        <VBox alignment="CENTER" spacing="5">
            <Label text="PIZZATTACK"
                   style="-fx-font-size: 56px; -fx-font-weight: 900; -fx-text-fill: #e87800; -fx-letter-spacing: 6px; -fx-effect: dropshadow(three-pass-box, #ff4500, 15, 0.3, 0, 0);"/>
            <Label text="MANUEL DE SURVIE DU CHEF CUISTOT"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ded0b6; -fx-letter-spacing: 4px;"/>
            <Region prefHeight="10"/>
        </VBox>

        <HBox spacing="25" alignment="CENTER" VBox.vgrow="ALWAYS">

            <VBox spacing="20" prefWidth="410" minWidth="380" maxHeight="560"
                  style="-fx-background-color: rgba(30, 8, 11, 0.85); -fx-padding: 25px; -fx-background-radius: 16px; -fx-border-color: rgba(232, 120, 0, 0.3); -fx-border-width: 1.5px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 10, 0, 0, 0);">

                <Label text="L'HISTOIRE" style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #e87800; -fx-letter-spacing: 1px;"/>

                <TextFlow lineSpacing="6.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Text text="Le monde a sombré. Toute la nourriture a perdu son goût, transformant la population en zombies obsédés par la moindre sensation gustative.&#10;&#10;" style="-fx-fill: #ded0b6; -fx-font-size: 14px;"/>
                        <Text text="L'odeur de votre four à bois les a attirés vers la pizzeria Hechik, unique gardienne des saveurs. Défendez vos cuisines face aux vagues de clients affamés !&#10;&#10;" style="-fx-fill: #ded0b6; -fx-font-size: 14px;"/>
                        <Text text="Placez vos défenses pour les empêcher d'atteindre vos précieuses pizzas." style="-fx-fill: #ffaa44; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    </children>
                </TextFlow>

                <Region style="-fx-background-color: rgba(232, 120, 0, 0.2); -fx-min-height: 1px;"/>

                <Label text="RÈGLES D'OR" style="-fx-font-size: 16px; -fx-font-weight: 900; -fx-text-fill: #ff8c00;"/>
                <VBox spacing="10">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label  style="-fx-font-size: 16px;"/>
                        <Label text="+10 Tickets par élimination" style="-fx-text-fill: #ded0b6; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    </HBox>

                </VBox>
            </VBox>

            <VBox spacing="15" prefWidth="430" minWidth="400" maxHeight="560"
                  style="-fx-background-color: rgba(30, 8, 11, 0.85); -fx-padding: 25px; -fx-background-radius: 16px; -fx-border-color: #e87800; -fx-border-width: 2px; -fx-effect: dropshadow(three-pass-box, rgba(232,120,0,0.15), 15, 0, 0, 0);">

                <Label text="VOTRE ARSENAL" style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #e87800; -fx-letter-spacing: 1px;"/>

                <VBox spacing="14" VBox.vgrow="ALWAYS">
                    <VBox spacing="2" style="-fx-background-color: rgba(255,255,255,0.03); -fx-padding: 8px 12px; -fx-background-radius: 6px;">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="MITRAILLETTE FRITE" style="-fx-text-fill: #ffaa44; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="Cadence Max" style="-fx-text-fill: #857e72; -fx-font-size: 11px;"/>
                        </HBox>
                        <Label text="Portée : 150 | Dégâts : 4 | Cadence ultra-rapide (Vitesse 4)." style="-fx-text-fill: #ded0b6; -fx-font-size: 13px;" wrapText="true"/>
                    </VBox>
                    <VBox spacing="2" style="-fx-background-color: rgba(255,255,255,0.03); -fx-padding: 8px 12px; -fx-background-radius: 6px;">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="LANCE-BURGER" style="-fx-text-fill: #ffaa44; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="Artillerie" style="-fx-text-fill: #857e72; -fx-font-size: 11px;"/>
                        </HBox>
                        <Label text="Portée : 180 | Dégâts : 15 | Impact lourd mais très lent (Vitesse 60)." style="-fx-text-fill: #ded0b6; -fx-font-size: 13px;" wrapText="true"/>
                    </VBox>
                    <VBox spacing="2" style="-fx-background-color: rgba(255,255,255,0.03); -fx-padding: 8px 12px; -fx-background-radius: 6px;">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="BARBECUE (PIÈGE)" style="-fx-text-fill: #ffaa44; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="Zone au Sol" style="-fx-text-fill: #857e72; -fx-font-size: 11px;"/>
                        </HBox>
                        <Label text="Portée : 12 | Dégâts : 1 | Brûle les ennemis et applique des dégâts continus." style="-fx-text-fill: #ded0b6; -fx-font-size: 13px;" wrapText="true"/>
                    </VBox>
                    <VBox spacing="2" style="-fx-background-color: rgba(255,255,255,0.03); -fx-padding: 8px 12px; -fx-background-radius: 6px;">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="BAC À GLACE (PIÈGE)" style="-fx-text-fill: #ffaa44; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="Contrôle" style="-fx-text-fill: #857e72; -fx-font-size: 11px;"/>
                        </HBox>
                        <Label text="Portée : 12 | Dégâts : 0 | Réduit instantanément de moitié la vitesse des clients." style="-fx-text-fill: #ded0b6; -fx-font-size: 13px;" wrapText="true"/>
                    </VBox>
                </VBox>
            </VBox>

            <VBox spacing="15" prefWidth="430" minWidth="400" maxHeight="560"
                  style="-fx-background-color: rgba(30, 8, 11, 0.85); -fx-padding: 25px; -fx-background-radius: 16px; -fx-border-color: rgba(232, 120, 0, 0.3); -fx-border-width: 1.5px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 10, 0, 0, 0);">

                <Label text="LES CLIENTS HOSTILES" style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #e87800; -fx-letter-spacing: 1px;"/>

                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <HBox spacing="10" style="-fx-background-color: rgba(0,0,0,0.2); -fx-padding: 8px; -fx-background-radius: 6px;" alignment="CENTER_LEFT">
                        <Label  style="-fx-font-size: 20px;"/>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="ZOMBIE NORMAL" style="-fx-text-fill: #ded0b6; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                            <Label text="20 PV | Vitesse : 2.0 | Dégâts Cuisine : 2" style="-fx-text-fill: #857e72; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="10" style="-fx-background-color: rgba(0,0,0,0.2); -fx-padding: 8px; -fx-background-radius: 6px;" alignment="CENTER_LEFT">
                        <Label  style="-fx-font-size: 20px;"/>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="ZOMBIE RAPIDE" style="-fx-text-fill: #ffaa44; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                            <Label text="15 PV | Vitesse éclair : 4.5 | Dégâts Cuisine : 3" style="-fx-text-fill: #857e72; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="10" style="-fx-background-color: rgba(0,0,0,0.2); -fx-padding: 8px; -fx-background-radius: 6px;" alignment="CENTER_LEFT">
                        <Label  style="-fx-font-size: 20px;"/>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="ZOMBIE GROS" style="-fx-text-fill: #ded0b6; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                            <Label text="130 PV | Vitesse : 1.5 | Dégâts Cuisine : 15" style="-fx-text-fill: #857e72; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="10" style="-fx-background-color: rgba(0,0,0,0.2); -fx-padding: 8px; -fx-background-radius: 6px;" alignment="CENTER_LEFT">
                        <Label style="-fx-font-size: 20px;"/>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="ZOMBIE FAMILLE" style="-fx-text-fill: #ded0b6; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                            <Label text="40 PV | À sa mort, il se divise en 4 Zombies Normaux !" style="-fx-text-fill: #857e72; -fx-font-size: 12px;" wrapText="true"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="10" style="-fx-background-color: rgba(232,120,0,0.08); -fx-padding: 8px; -fx-background-radius: 6px; -fx-border-color: rgba(232,120,0,0.3); -fx-border-width: 1px;" alignment="CENTER_LEFT">
                        <Label  style="-fx-font-size: 20px;"/>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="LE BOSS" style="-fx-text-fill: #ff4500; -fx-font-weight: 900; -fx-font-size: 13px;"/>
                            <Label text="2000 PV | Vitesse : 3.0 | Dégâts Cuisine : 100" style="-fx-text-fill: #ffaa44; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>

        <Region prefHeight="5"/>

        <Button fx:id="nextBtn"
                text="OUVRIR LE RESTAURANT"
                onAction="#aide"
                style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: #0f0203; -fx-padding: 18px 80px; -fx-cursor: hand; -fx-background-radius: 10px;
                       -fx-background-color: ${nextBtn.hover ? '#ff8c00' : '#e87800'};
                       -fx-scale-x: ${nextBtn.hover ? 1.03 : 1.0};
                       -fx-scale-y: ${nextBtn.hover ? 1.03 : 1.0};
                       -fx-effect: ${nextBtn.hover ? 'dropshadow(three-pass-box, #ff4500, 20, 0, 0, 0)' : 'dropshadow(three-pass-box, rgba(232,120,0,0.4), 15, 0, 0, 0)'};" />
    </VBox>
</StackPane>
