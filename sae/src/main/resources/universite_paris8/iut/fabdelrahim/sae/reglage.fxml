<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="universite_paris8.iut.fabdelrahim.sae.controller.reglageController"
      spacing="20" alignment="CENTER"
      prefWidth="300" prefHeight="400"
      style="-fx-background-color: #6E2934;">

    <Button fx:id="leave" styleClass="btn" text="Reprendre" onAction="#quitte"/>
    <Button text="Recommencer"
            onAction="#recommencerJeu"
            styleClass="btn-restart"
            prefWidth="180"
            prefHeight="40"/>
    <HBox alignment="CENTER_LEFT" spacing="8" maxWidth="200">
        <Label text="🔊"/>
        <Slider fx:id="volume"
                min="0" max="100" value="50"
                HBox.hgrow="ALWAYS"/>
    </HBox>
    <Label text="Crédit : MRFF"/>


</VBox>

